    "actionConfiguration": {
      "body": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <title>แจ้งเตือนการอนุมัติ Prospect</title>\n</head>\n<body style=\"margin:0; padding:0; background-color:#f4f6f8; font-family: Arial, Helvetica, sans-serif;\">\n\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td align=\"center\" style=\"padding:20px;\">\n\n        <!-- Email Container -->\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#ffffff; border-radius:6px;\">\n\n          <!-- Header -->\n          <tr>\n            <td style=\"padding:20px; background-color:#2f80ed; color:#ffffff; border-radius:6px 6px 0 0;\">\n              <h2 style=\"margin:0; font-size:20px;\">แจ้งเตือนระบบ</h2>\n            </td>\n          </tr>\n\n          <!-- Body -->\n          <tr>\n            <td style=\"padding:20px; color:#333333; font-size:14px; line-height:1.6;\">\n              <p style=\"margin-top:0;\">\n                เรียน ท่านผู้บริหาร\n              </p>\n\n              <p>\n\t     ฝ่ายการตลาดได้ทำการ qualify ข้อมูล Prospect เรียบร้อย และขณะนี้อยู่ระหว่างรอการอนุมัติจากท่าน\n              </p>\n\n              <p>\n                กรุณากดที่ลิงก์ด้านล่างเพื่อเข้าสู่ระบบการอนุมัติ Prospect\n              </p>\n\n              <!-- Button -->\n              <p style=\"text-align:center; margin:30px 0;\">\n                <a href=\"{{appsmith.URL.fullPath}}\"\n                   style=\"background-color:#2f80ed; color:#ffffff; text-decoration:none; padding:12px 24px; border-radius:4px; display:inline-block;\">\n                  เข้าสู่ระบบการอนุมัติ\n                </a>\n              </p>\n\n              <p>\n                หากไม่สามารถกดปุ่มได้ กรุณาคัดลอกลิงก์ด้านล่างไปวางในเบราว์เซอร์  \n                <br>\n                <a href=\"{{appsmith.URL.fullPath}}\"\n                   style=\"color:#2f80ed;\">\n                  {{appsmith.URL.fullPath}}\n                </a>\n              </p>\n\n              <p style=\"margin-top:30px;\">\n                ขอแสดงความนับถือ<br>\n                <strong>RPA</strong>\n              </p>\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"padding:15px; background-color:#f1f1f1; color:#777777; font-size:12px; text-align:center; border-radius:0 0 6px 6px;\">\n              อีเมลฉบับนี้ถูกส่งจาก RPA กรุณาอย่าตอบกลับ\n            </td>\n          </tr>\n\n        </table>\n        <!-- End Container -->\n\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>",
      "encodeParamsToggle": true,
      "formData": {
